# === CORE ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# === SUPABASE (Auth + Database) ===
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only. Required by the Dodo webhook + admin tasks. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth is configured in the Supabase dashboard:
#   Authentication → Providers → Google (add Client ID/Secret)
#   Authentication → URL Configuration → add redirect URL: {APP_URL}/auth/callback

# === AI (Google Gemini) ===
GEMINI_API_KEY=your_gemini_api_key

# === EMAIL (Resend) ===
RESEND_API_KEY=your_resend_api_key

# === PAYMENTS (Dodo Payments) ===
# Dashboard → Developer → API Keys / Webhooks
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_signing_secret
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Product IDs created in the Dodo dashboard (subscription products)
DODO_PRO_PRODUCT_ID=prod_your_pro_product_id
DODO_ENTERPRISE_PRODUCT_ID=prod_your_enterprise_product_id
